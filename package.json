{
  "name": "campaigner",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "shared",
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npm run build:shared && concurrently \"npm run dev:shared\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:shared": "cd shared && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:shared && npm run build:backend && npm run build:frontend",
    "build:shared": "cd shared && npm run build",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "db:migrate": "cd backend && npm run migrate",
    "doctor": "node scripts/doctor.mjs",
    "chunker": "node scripts/chunker.mjs",
    "smoke": "node scripts/smoke/index.mjs",
    "smoke:up": "node scripts/smoke-runner.mjs",
    "backend:start:once": "cd backend && npx tsx src/index.ts"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "kill-port": "^2.0.1",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "globby": "^16.1.1",
    "picocolors": "^1.1.1",
    "remark-gfm": "^4.0.1",
    "tiktoken": "^1.0.22"
  }
}
