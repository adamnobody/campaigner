# Backend loads dotenv from the repository root: `.env` (see `backend/src/index.ts`).
# Copy this file to the repo root as `.env` and adjust values.

PORT=3001
FRONTEND_URL=http://localhost:5173
# Optional: path to built frontend for production static serving (default: ../frontend/dist)
FRONTEND_DIST_PATH=
# Optional: SQLite file path relative to repository root (default: ./data/campaigner.sqlite)
DATABASE_PATH=./data/campaigner.sqlite
