# Vite loads env by mode (see https://vitejs.dev/guide/env-and-mode.html):
#
#   development  → .env.development  (npm run dev / dev:http)     → VITE_TRANSPORT=http
#   tauri        → .env.tauri        (npm run dev:tauri, tauri:dev) → VITE_TRANSPORT=tauri
#   production   → .env.production   (npm run build)             → VITE_TRANSPORT=http
#
# Optional per-machine override (gitignored): copy to .env.local or .env.tauri.local
# VITE_TRANSPORT=tauri
