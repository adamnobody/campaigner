# .gitignore

# ==================== Dependencies ====================
node_modules/
package-lock.json
chunks/
.pnp
.pnp.js

# ==================== Build ====================
dist/
build/
shared/dist/
backend/dist/
frontend/dist/
dist-electron/

# ==================== Local data (SQLite, uploads) ====================
# Создаётся при первом запуске бэкенда; в репозиторий не коммитим.
/data/*
!data/.gitkeep

# ==================== Environment ====================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ==================== IDE ====================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ==================== Logs ====================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==================== OS ====================
.DS_Store
Desktop.ini
ehthumbs.db

# ==================== TypeScript ====================
*.tsbuildinfo

# ==================== Vite ====================
*.local

# ==================== Misc ====================
.cache/
.temp/
.tmp/
coverage/
.cursor/
AGENTS.md
PROJECT_TREE.md
docs/
